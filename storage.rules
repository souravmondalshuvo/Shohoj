rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isBracuUser() {
      return request.auth != null
        && request.auth.token.email.matches('^[^@]+@g[.]bracu[.]ac[.]bd$');
    }

    function isAdmin() {
      // Set this to your Firebase UID — must match isAdmin() in firestore.rules.
      return request.auth != null
        && request.auth.uid == 'YOUR_FIREBASE_UID_HERE';
    }

    // Past papers & notes — uploaded files for the Phase 2 library.
    // Path: /papers/{courseCode}/{filename}
    // Reads gated to BRACU students; uploads capped at 10 MB and limited to
    // PDFs and images. Admin can delete files when rejecting paper docs.
    match /papers/{courseCode}/{filename} {
      allow read: if isBracuUser();

      allow create: if isBracuUser()
        && request.resource.size > 0
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*');

      allow update: if false;
      allow delete: if isAdmin();
    }

    // Catch-all: deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
