rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────
    function isBracuUser() {
      return request.auth != null
        && request.auth.token.email.matches('^[^@]+@g[.]bracu[.]ac[.]bd$');
    }

    function isAdmin() {
      // Set to your Firebase UID (visible in Firebase console → Authentication)
      return request.auth != null
        && request.auth.uid == 'YOUR_FIREBASE_UID_HERE';
    }

    function validRating(v) {
      return v is int && v >= 1 && v <= 5;
    }

    function validCourseCode(code) {
      return code is string
        && code.matches('^[A-Z]{2,4}[0-9]{3}[A-Z]?$');
    }

    function validReviewId(id) {
      return id is string
        && id.matches('^[A-Z]{2,6}_[A-Z]{2,4}[0-9]{3}[A-Z]?_[a-f0-9]{64}$');
    }

    function validRatings(r) {
      return r.keys().hasOnly(['teaching','marking','behavior','difficulty','workload'])
        && r.keys().hasAll(['teaching','marking','behavior','difficulty','workload'])
        && validRating(r.teaching)
        && validRating(r.marking)
        && validRating(r.behavior)
        && validRating(r.difficulty)
        && validRating(r.workload);
    }

    function validReviewPayload(d) {
      // Exact key set — no extra fields allowed.
      return d.keys().hasOnly(['facultyInitials','courseCode','semester','ratings','text','createdAt'])
        && d.keys().hasAll(['facultyInitials','courseCode','ratings','createdAt'])
        && d.facultyInitials is string
        && d.facultyInitials.matches('^[A-Z]{2,6}$')
        && validCourseCode(d.courseCode)
        && validRatings(d.ratings)
        && (!('text' in d) || (d.text is string && d.text.size() <= 500))
        && (!('semester' in d) || (d.semester is string && d.semester.size() <= 40))
        && d.createdAt == request.time;
    }

    function validReviewReportPayload(d) {
      return d.keys().hasOnly(['reviewId','reason','reporterUid','createdAt'])
        && d.keys().hasAll(['reviewId','reason','reporterUid','createdAt'])
        && validReviewId(d.reviewId)
        && exists(/databases/$(database)/documents/facultyReviews/$(d.reviewId))
        && d.reason is string
        && d.reason.size() >= 3
        && d.reason.size() <= 300
        && d.reporterUid is string
        && d.reporterUid == request.auth.uid
        && d.createdAt == request.time;
    }

    // ── User data: scoped to own UID, BRACU domain only ──────────────────
    match /users/{uid} {
      allow read, write, delete: if isBracuUser() && request.auth.uid == uid;
    }

    // ── Faculty reviews: BRACU students can submit & read ────────────────
    // Each review doc uses a DETERMINISTIC ID:
    //   {facultyInitials}_{courseCode}_{64-char lowercase hex}
    // where the hex suffix = sha256(uid + '|' + facultyInitials + '|' + courseCode).
    // This enforces one review per (user, faculty, course) without storing the
    // uid anywhere in the doc body.
    //
    // Trust model: the client computes the hash, so a determined adversary
    // who knows a victim's uid could pre-claim that victim's review slot
    // before they submit. That attack still requires obtaining the target's
    // Firebase uid (not just their email). For stronger guarantees, move
    // review creation behind a trusted backend / Cloud Function.
    match /facultyReviews/{reviewId} {
      allow read: if isBracuUser();

      allow create: if isBracuUser()
        && validReviewId(reviewId)
        && validReviewPayload(request.resource.data)
        && reviewId.split('_')[0] == request.resource.data.facultyInitials
        && reviewId.split('_')[1] == request.resource.data.courseCode;

      // Client reviews are append-only. This narrows the abuse window for
      // deterministic doc IDs and keeps public review content tamper-evident.
      allow update, delete: if false;
    }

    // ── Review reports (abuse flagging) ──────────────────────────────────
    // Any signed-in BRACU user can create one report per review. Reports are
    // not readable from the client — admins triage via the Firebase console /
    // admin SDK.
    match /reviewReports/{reportId} {
      allow read: if false;

      allow create: if isBracuUser()
        && validReviewReportPayload(request.resource.data)
        && reportId == request.auth.uid + '_' + request.resource.data.reviewId;

      allow update, delete: if false;
    }

    // ── Faculty profiles: read-only for students, admin-seeded ───────────
    match /facultyProfiles/{initials} {
      allow read: if isBracuUser();
      allow write: if false;
    }

    // ── App feedback ─────────────────────────────────────────────────────
    function validFeedbackType(t) {
      return t == 'bug' || t == 'feature' || t == 'general';
    }

    function validFeedbackPayload(d) {
      return d.keys().hasOnly(['type','text','context','anonymous','uid','createdAt'])
        && d.keys().hasAll(['type','text','anonymous','createdAt'])
        && validFeedbackType(d.type)
        && d.text is string
        && d.text.size() >= 3
        && d.text.size() <= 500
        && d.anonymous is bool
        && d.createdAt == request.time
        && (!('context' in d) || d.context is map)
        && (!('uid' in d) || d.uid == request.auth.uid);
    }

    match /appFeedback/{feedbackId} {
      allow read:   if isBracuUser();
      allow create: if isBracuUser() && validFeedbackPayload(request.resource.data);
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /appFeedbackUpvotes/{voteId} {
      allow read:   if isBracuUser();
      allow create: if isBracuUser()
        && request.resource.data.keys().hasOnly(['feedbackId','uid','createdAt'])
        && request.resource.data.keys().hasAll(['feedbackId','uid','createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.feedbackId is string
        && request.resource.data.feedbackId.size() > 0
        && request.resource.data.createdAt == request.time
        && voteId == request.resource.data.feedbackId + '_' + request.auth.uid;
      allow delete: if isBracuUser() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── Catch-all: deny everything else ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
